:81 {
	@transform_port_query {
		query XTransformPort=*
	}

	handle @transform_port_query {
		reverse_proxy localhost:{query.XTransformPort} {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Real-IP {remote_host}
		}
	}

	# Whatomate API routes - proxy to Go backend
	@api {
		path /api/*
	}
	handle @api {
		reverse_proxy localhost:8080 {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Real-IP {remote_host}
		}
	}

	# Whatomate WebSocket
	@ws {
		path /ws/*
	}
	handle @ws {
		reverse_proxy localhost:8080 {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Real-IP {remote_host}
			header_up Connection {>Connection}
			header_up Upgrade {>Upgrade}
		}
	}

	# Whatomate frontend (Vue.js) - serve static files
	@frontend {
		not path /api/*
		not path /ws/*
		not path /_next/*
		not path /__nextjs_original-stack-frame*
	}
	handle @frontend {
		reverse_proxy localhost:3000 {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Real-IP {remote_host}
		}
	}

	handle {
		reverse_proxy localhost:3000 {
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Real-IP {remote_host}
		}
	}
}
